0953,40.218317937861336],[-5.429718071746405,40.252260641698285],[-5.530854896634619,40.19472480059822],[-5.609928156774998,40.21548637305604],[-5.692550816221028,40.292111612859145],[-5.764877426458526,40.28078545118356],[-5.7974021716151585,40.35325033746846],[-5.94155599196801,40.28442413874844],[-6.082262919612211,40.363216462989605],[-6.1985740648058965,40.48143609861534],[-6.344529366826808,40.44278466201591],[-6.375850129675401,40.40019572459785],[-6.536168179574818,40.34725286178922],[-6.5869083023059,40.270730222910686],[-6.867992134366101,40.264331399169265],[-7.012689996870998,40.22544806097286],[-7.018950546800982,40.14258460084092],[-6.940791481180766,40.111745418488404],[-6.8666633809623425,40.0152326172553],[-6.903598115172696,39.87069536136387],[-6.987210651400378,39.81002038419508],[-7.015521559590643,39.67042373377022],[-7.331167937628834,39.64098920620766],[-7.541686516276699,39.66367710356275]]]]}]},"numberOfSites":6,"area":152.5,"areaSd":88.6,"measurements":[{"term":{"@type":"Term","name":"Organic carbon (per ha)","termType":"measurement","@id":"organicCarbonPerHa","units":"kg C / ha"},"value":[77600],"sd":[8400],"statsDefinition":"sites","dates":["2018"],"depthUpper":0,"depthLower":30,"methodClassification":"on-site physical measurement","methodClassificationDescription":"Measurement is an average across 110 sites, covering both organic and conventional farms","@type":"Measurement"},{"term":{"@type":"Term","name":"Organic carbon (per ha)","termType":"measurement","@id":"organicCarbonPerHa","units":"kg C / ha"},"value":[57580],"dates":["1996"],"depthUpper":0,"depthLower":30,"methodClassification":"modelled using other measurements","methodClassificationDescription":"The quantification of the soil C sequestration rates in dehesa systems were based on the comparison of soil C stock (30 cm depth) directly measured in 2018 with stocks measured and reported by the literature during an average of 22 years before on dehesa farms. Therefore, the carbon stock in 1996 has been estimated using the carbon stock in 2018, and the calculated SOC sequestration rate per year in the study.","@type":"Measurement"},{"term":{"@type":"Term","name":"Above ground biomass","termType":"measurement","@id":"aboveGroundBiomass","units":"kg C / ha"},"value":[7250],"sd":[890],"statsDefinition":"sites","dates":["2007"],"methodClassification":"modelled using other measurements","methodClassificationDescription":"The C sequestration of the vegetal biomass was estimated based on the National Forest Inventory (NFI) data (MAPA, 2020), making the comparison between the C stock described in the second (1986–1996) and third editions (1997–2007), with a 10 year gap. 3823 dehesa plots were assessed, with the following criteria: a) points that were sampled in both NFI2 and NFI3; b) main tree species (>50%) represented by Quercus sp.; c) tree density below 80 trees ha− 1. Criteria b) and c) were established following the definition of dehesa systems of Pulido et al. (2010). NFIs comparison and management was done using Basifor 2.0 software (Bravo Oviedo et al., 2004). Structural measurements of NFI2 and NFI3 for all 3823 selected plots were converted to biomass C densities by using allometric equations. IPCC (2006) guide equations for above and belowground tree biomass was used, and specific Biomass Expansion Factor (BEF), Root-to-Shoot Ratio (R), and Carbon Fraction for each species were used when avail- able in the Montero et al. (2005) database.","@type":"Measurement"},{"term":{"@type":"Term","name":"Above ground biomass","termType":"measurement","@id":"aboveGroundBiomass","units":"kg C / ha"},"value":[6550],"dates":["1996"],"methodClassification":"modelled using other measurements","methodClassificationDescription":"The C sequestration of the vegetal biomass was estimated based on the National Forest Inventory (NFI) data (MAPA, 2020), making the comparison between the C stock described in the second (1986–1996) and third editions (1997–2007), with a 10 year gap. Tree biomass carbon stock in 1996 was estimated using the stock in 2007, and the calculated carbon sequestration rate per year.","@type":"Measurement"}],"management":[{"term":{"@type":"Term","@id":"nativePasture","name":"Native pasture","termType":"pastureManagement","units":"% area"},"value":100,"endDate":"2019","@type":"Management"}],"dataPrivate":false,"name":"Permanent pasture - Spain","boundaryArea":4789840.980632569,"schemaVersion":"30.4.0","originalId":"Organic_Average_Farm"}