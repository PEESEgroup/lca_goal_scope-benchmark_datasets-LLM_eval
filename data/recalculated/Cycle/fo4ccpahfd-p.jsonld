{"@context": "https://www.hestia.earth/schema/Cycle.jsonld", "createdAt": "2025-05-16", "@id": "fo4ccpahfd-p", "@type": "Cycle", "endDate": "2015", "functionalUnit": "relative", "functionalUnitDetails": "The functional unit has been selected as the total mass of all grades of Grana Padano cheese produced by the factory aggregated together, over one year.", "startDateDefinition": "one year prior", "cycleDuration": 365, "site": {"@type": "Site", "@id": "j4rfcratct7x"}, "siteDuration": 365, "defaultSource": {"@id": "m-dxp30yerdo", "@type": "Source"}, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "\"Primary data were directly collected by means of questionnaires and surveys in the cheese factory\"", "inputs": [{"term": {"@type": "Term", "termType": "animalProduct", "name": "Milk, cow, raw (FPCM)", "units": "kg FPCM", "@id": "milkCowRawFpcm"}, "value": [86165000], "description": "\"At farm gate, to evaluate the environmental impacts of milk production, the FU was 1 kg of Fat and Protein Corrected Milk (FPCM)\"", "transport": [{"term": {"@type": "Term", "termType": "transport", "name": "Chilled freight, lorry", "units": "tkm", "@id": "chilledFreightLorry"}, "value": 3446600, "returnLegIncluded": false, "description": "\"Collection of the milk from the dairy farms and the transportation to the cheese factory\". \"The five farms were located at an average distance of 40 km from the cheese factory\". \"The milk must not be refrigerated below 8 °C, neither at the farm nor during transportation to the cheese factory\".", "@type": "Transport"}], "@type": "Input"}, {"term": {"@type": "Term", "name": "Rennet", "termType": "feedFoodAdditive", "@id": "rennet", "units": "kg"}, "value": [3210], "@type": "Input"}, {"term": {"@type": "Term", "name": "Lysozyme", "termType": "feedFoodAdditive", "@id": "lysozyme", "units": "kg"}, "value": [1830], "@type": "Input"}, {"term": {"@type": "Term", "name": "Sodium chloride", "termType": "feedFoodAdditive", "@id": "sodiumChloride", "units": "kg"}, "value": [120000], "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Natural gas", "units": "m3", "@id": "naturalGas"}, "value": [866099.0518], "operation": {"@type": "Term", "name": "Aging food", "termType": "operation", "@id": "agingFood", "units": "hour"}, "description": "\"natural gas utilized to maintain the required temperature and humidity of warehouse [cheese] storage\". \"cheese is stored in the ripening room at a temperature in the range 15–22 °C\" \"which must last a minimum of 9 months\". \"In this study, a 12-month ripening period was considered.\"\n12 months in hours is reflected in the operation value.\nFuel input value is from Table 1, which is in MWh, but required unit is cubic metres. \nHeating values: https://www.hestia.earth/term/naturalGas\nLower heating value: https://foodstepscore.slack.com/archives/C04PBBUBR5G/p1740412760230709?thread_ts=1740412239.261559&cid=C04PBBUBR5G", "@type": "Input"}, {"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "units": "kWh"}, "value": [4747000], "@type": "Input"}, {"term": {"@type": "Term", "name": "Detergent unspecified (AI)", "termType": "otherOrganicChemical", "@id": "detergentUnspecifiedAi", "units": "kg active ingredient"}, "value": [31500], "operation": {"@type": "Term", "name": "Cleaning, with clean-in-place", "termType": "operation", "@id": "cleaningWithCleanInPlace", "units": "hour"}, "@type": "Input"}], "practices": [{"term": {"@type": "Term", "name": "Centrifugation, machine unspecified", "termType": "operation", "@id": "centrifugationMachineUnspecified", "units": "hour"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Pasteurising, machine unspecified", "termType": "operation", "@id": "pasteurisingMachineUnspecified", "units": "hour"}, "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Cooling food, with refrigerator", "units": "hour", "@id": "coolingFoodWithRefrigerator"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Heating (food processing), machine unspecified", "termType": "operation", "@id": "heatingFoodProcessingMachineUnspecified", "units": "hour"}, "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Coagulation, with rennet", "units": "hour", "@id": "coagulationWithRennet"}, "primary": true, "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Mixing, with churn", "units": "hour", "@id": "mixingWithChurn"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Aging food", "termType": "operation", "@id": "agingFood", "units": "hour"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Salting, with brine", "termType": "operation", "@id": "saltingWithBrine", "units": "hour"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Storage, ambient", "termType": "operation", "@id": "storageAmbient", "units": "hour"}, "value": [8640], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Extruding, machine unspecified", "termType": "operation", "@id": "extrudingMachineUnspecified", "units": "hour"}, "@type": "Practice"}], "products": [{"term": {"@type": "Term", "name": "Ripened cheese", "termType": "processedFood", "@id": "ripenedCheese", "units": "kg"}, "value": [6592000], "primary": true, "economicValueShare": 76.14669731188168, "description": "There are multiple products in this process, Grana Padano \"with two different quality levels (First and Second choice), and generic hard cheese grated which is the cheese that does not fully accomplish the specific quality\". All the masses of these products have been aggregated together.", "@type": "Product", "updated": ["economicValueShare"], "updatedVersion": ["0.70.3"]}, {"term": {"@type": "Term", "name": "Whey, liquid", "termType": "processedFood", "@id": "wheyLiquid", "units": "kg"}, "value": [61806000], "economicV