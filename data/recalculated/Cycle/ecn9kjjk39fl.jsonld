{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2023-10-16", "updatedAt": "2025-04-25", "@id": "ecn9kjjk39fl", "@type": "Cycle", "description": "Processing and packaging cycle to transform milk into various dairy products.", "endDate": "2019", "functionalUnit": "relative", "site": {"@type": "Site", "@id": "koy73hgdexem"}, "defaultSource": {"@id": "3tmw64utoxmb", "@type": "Source"}, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "Each dairy factory was visited once for filling in the life cycle inventory questionnaire. Inputs were recorded from official registers and invoices and included the amount of milk supplied by each farm as well as the energy sources (fuel, methane gas, electricity), cleaning agents and packaging materials (tetrapak, glass, food wrapping paper, plastic) used. Since all the dairies except one had small size in terms of milk processed per day, data about the production input were not available specifically for each product. Thus data collection was performed at the dairy scale, assuming that the production input were homogenously used in the production of the different dairy products", "inputs": [{"term": {"@type": "Term", "termType": "animalProduct", "name": "Milk, cow, raw (FPCM)", "units": "kg FPCM", "@id": "milkCowRawFpcm"}, "value": [100], "impactAssessment": {"@id": "wmmdkdku0dz0", "@type": "ImpactAssessment"}, "impactAssessmentIsProxy": false, "@type": "Input", "properties": [{"term": {"@type": "Term", "termType": "property", "name": "Fat content", "units": "%", "@id": "fatContent"}, "value": 4, "share": 100, "@type": "Property", "added": ["term", "value", "share"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "name": "Crude protein content", "termType": "property", "@id": "crudeProteinContent", "units": "%"}, "value": 3.3, "share": 100, "@type": "Property", "added": ["term", "value", "share"], "addedVersion": ["0.70.0"