t fibre content", "termType": "property", "units": "%"}, "value": 56.8, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "phosphorusContentAsP", "name": "Phosphorus content (as P)", "termType": "property", "units": "%"}, "value": 0.26, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "potassiumContentAsK", "name": "Potassium content (as K)", "termType": "property", "units": "%"}, "value": 2.56, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "sodiumContent", "name": "Sodium content", "termType": "property", "units": "%"}, "value": 0.17, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "totalLipidContent", "name": "Total lipid content", "termType": "property", "units": "%"}, "value": 3.07, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "waterSolubleCarbohydrateContent", "name": "Water soluble carbohydrate content", "termType": "property", "units": "%"}, "value": 4.71, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "zincContent", "name": "Zinc content", "termType": "property", "units": "%"}, "value": 0.0, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}], "@type": "Input", "updated": ["properties"], "updatedVersion": ["0.70.0"]}, {"term": {"@type": "Term", "name": "Generic grass, hay", "termType": "crop", "@id": "genericGrassHay", "units": "kg"}, "value": [79078], "isAnimalFeed": true, "methodClassification": "modelled", "methodClassificationDescription": "Consumption of grassland-derived feedstuffs was only roughly known, because of year-to-year variability and lack of available data in farms with a traditional feeding system based on hay consumption ad-libitum. \nSo, we recorded the total permanent farm agricultural area (perm_FAA), its proportion destined to each crop, and the types and quantities of fertilizers (organic and chemical) in order to estimate the grassland production. We estimated the grassland production (GRASSLAND_model) on the basis of the area and of N fertilization rate (Scotton et al., 2005). Afterwards, we compared GRASSLAND_model with the feed intake calculation (i.e., the sum of hay, grass silage and grass at pasture amounts as obtained from feed rations and animal NE requirements, GRASSLAND_intake), subtracted the field losses (losses factors derived from Bretscher, 2010), assuming that GRASSLAND_intake amount was covered by the GRASSLAND_model. When a deficit was found, we implicitly assumed that a deficit-correspondent amount of hay (first marginal feedstuff) and secondly of grass silage (second marginal feedstuff) were purchased.", "min": [0], "max": [192508], "sd": [1212], "statsDefinition": "sites", "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 100, "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "acidDetergentFibreContent", "name": "Acid detergent fibre content", "termType": "property", "units": "%"}, "value": 41.12, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "ashContent", "name": "Ash content", "termType": "property", "units": "%"}, "value": 9.55, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "calciumContent", "name": "Calcium content", "termType": "property", "units": "%"}, "value": 0.6, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "copperContent", "name": "Copper content", "termType": "pro