ype": "Term", "@id": "manganeseContent", "name": "Manganese content", "termType": "property", "units": "%"}, "value": 0.0, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "neutralDetergentFibreContent", "name": "Neutral detergent fibre content", "termType": "property", "units": "%"}, "value": 56.8, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "phosphorusContentAsP", "name": "Phosphorus content (as P)", "termType": "property", "units": "%"}, "value": 0.26, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "potassiumContentAsK", "name": "Potassium content (as K)", "termType": "property", "units": "%"}, "value": 2.56, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "sodiumContent", "name": "Sodium content", "termType": "property", "units": "%"}, "value": 0.17, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "totalLipidContent", "name": "Total lipid content", "termType": "property", "units": "%"}, "value": 3.07, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "waterSolubleCarbohydrateContent", "name": "Water soluble carbohydrate content", "termType": "property", "units": "%"}, "value": 4.71, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "zincContent", "name": "Zinc content", "termType": "property", "units": "%"}, "value": 0.0, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}], "transport": [{"term": {"@type": "Term", "name": "Transport, unspecified", "termType": "transport", "@id": "transportUnspecified", "units": "tkm"}, "value": 0, "returnLegIncluded": true, "@type": "Transport"}], "@type": "Input", "updated": ["properties"], "updatedVersion": ["0.70.0"]}, {"term": {"@type": "Term", "termType": "soilAmendment", "name": "Sawdust", "units": "kg", "@id": "sawdust"}, "description": "Bedding", "isAnimalFeed": false, "value": [5852], "min": [0], "max": [57646], "sd": [387], "statsDefinition": "sites", "@type": "Input"}, {"term": {"@type": "Term", "name": "Generic grass, fresh forage", "termType": "forage", "@id": "genericGrassFreshForage", "units": "kg"}, "value": [48336], "isAnimalFeed": true, "producedInCycle": true, "min": [0], "max": [210368], "statsDefinition": "sites", "description": "Combination of both pasture grass at permanent farm and pasture grass at summer farm, averaged across all of the farms (some farms didn't practice transhumance to summer farm)", "methodClassification": "modelled", "methodClassificationDescription": "We estimated the grassland production (GRASSLAND_model) on the basis of the area and of N fertilization rate (Scotton et al., 2005). Afterwards, we compared GRASSLAND_model with the feed intake calculation (i.e., the sum of hay, grass silage and grass at pasture amounts as obtained from feed rations and animal NE requirements, GRASSLAND_intake), subtracted the field losses (losses factors derived from Bretscher, 2010), assuming that GRASSLAND_intake amount was covered by the GRASSLAND_model. When a deficit was found, we implicitly assumed that a deficit-correspondent amount of hay (first marginal feedstuff) and secondly of grass silage (second marginal feedstuff) were purchased.", "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Wheat, straw", "units": "kg", "@id": "wheatStraw"}, "value": [15580], "min": [0], "max": [179816], "sd": [617], "statsDefinition": "sites", "isAnimalFeed": false, "description": "Bedding", "@type": "Input"}, {"@type": "Input", "term": {"@type": "Term", "@id": "machineryInfrastructureDepreciatedAmountPerCycle", "name": "Machinery infrastructure, depreciated amount per Cycle", "termType": "material", "units": "kg/functional unit/Cycle"}, "model": {"@type": "Term", "@id": "agribalyse2016", "name": "Agribalyse (2016)", "termType": "model"}, "value": [535.304347826087], "added": ["term", "model", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}], "practices": [{"term": {"@type": "Term", "termType": "animalManagement", "name": "Milk yield per cow (FPCM)", "units": "kg / day", "@id": "milkYieldPerCowFpcm"}, "value": [17.534246575342465], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Stocking density, permanent pasture (average)", "termType": "animalManagement", "@id": "stockingDensityPermanentPastureAverage", "units": "animals / m2"}, "value": [0.00014423076923076924], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Not given directly in the study (only in LU/ha). So have added up the mean no. of animals in the herd and divided by the area of both winter and summer pasture areas.", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Indoor animal system", "termType": "system", "@id": "indoorAnimalSystem", "units": "% area"}, "value": [74.52054794520548], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Hilly pasture system", "termType": "system", "@id": "hillyPastureSystem", "units": "% area"}, "value": [12.73972602739726], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Confined pasture system", "termType": "system", "@id": "confinedPastureSystem", "units": "% area"}, "value": [12.73972602739726], "@type": "Practice"}, {"@type": "Practice", "term": {"@type": "Term", "@id": "stockingDensityAnimalHousingAverage", "name": "Stocking density, animal housing (average)", "termType": "animalManagement", "units": "animals / m2"}, "model": {"@type": "Term", "@id": "hestia", "name": "HESTIA", "termType": "model"}, "value": [0.2444444], "added": ["term", "model", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}], "animals": [{"animalId": "Cows", "term": {"@type": "Term", "termType": "liveAnimal", "name": "Dairy cattle, cow", "units": "number", "@id": "dairyCattleCow"}, "referencePeriod": "average", "value": 24, "methodClassification": "modelled", "methodClassificationDescription": "The herd size and composition were modelled on the basis of the mean number of cows, number of lactations (LacN), calving interval (CI), age at first calving and dry period length (DP). Derived from Berton et al., 2020", "properties": [{"term": {"@type": "Term", "name": "Liveweight per head", "termType": "property", "@id": "liveweightPerHead", "units": "kg liveweight / head"}, "value": 587, "methodClassification": "modelled", "methodClassificationDescription": "The body weight (BW) of replacement heifers and dairy cows was computed as follows: BW of the heifers at the age of first calving was assumed as 82% of mean culled cows’ BW (NRC, 2001), which was collected during the farm visit. Consequently, mean dairy cows BW was computed as the mean between culled cows and heifers at the age of first calving, weighed by the number of primiparous and dairy cows. Number of primiparous cows was equal to the number of culled cows, assuming a constant herd size.", "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "hoursWorkedPerDay", "name": "Hours worked per day", "termType": "property", "units": "hours / head / day"}, "methodModel": {"@type": "Term", "@id": "ipcc2019", "name": "IPCC (2019)", "termType": "model"}, "value": 0.0, "added": ["term", "methodModel", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "liveweightGain", "name": "Liveweight gain", "termType": "property", "units": "kg liveweight / head / day"}, "methodModel": {"@type": "Term", "@id": "ipcc2019", "name": "IPCC (2019)", "termType": "model"}, "value": 0.0, "added": ["term", "methodModel", "value"], "addedVersion": ["0.70.0", "0.70.