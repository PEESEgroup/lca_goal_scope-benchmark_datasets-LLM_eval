erm", "@id": "energyContentHigherHeatingValue", "name": "Energy content (higher heating value)", "termType": "property", "units": "MJ / kg"}, "value": 21.8, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "phosphorusContentAsP", "name": "Phosphorus content (as P)", "termType": "property", "units": "%"}, "value": 3.83, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Concentrates, alfalfa hay and maize silage were totally purchased (when farm used maize silage, it was either totally purchase or totally self-produced), and their share on the animal feed intake was available from the animal rations. Consequently, we calculated the annual amount of concentrates and alfalfa hay as the sum of estimated dry matter intake * feedstuff share (dry matter basis) * days * number of animal, for each livestock category and each period (winter, summer pasture at permanent farm and/or at summer farm). Afterwards, we checked that the calculated amount of each off-farm feedstuff was within the amount recorded in the commercial invoices, assuming the storehouse constant.", "@type": "Input", "updated": ["properties"], "updatedVersion": ["0.70.0"]}, {"term": {"@type": "Term", "termType": "crop", "name": "Maize, flour", "units": "kg", "@id": "maizeFlour"}, "value": [6118], "min": [0], "max": [66614], "sd": [323], "isAnimalFeed": true, "statsDefinition": "sites", "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 100, "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "acidDetergentFibreContent", "name": "Acid detergent fibre content", "termType": "property", "units": "%"}, "value": 3.66, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type