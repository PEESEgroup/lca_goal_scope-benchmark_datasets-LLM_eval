{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2023-10-16", "updatedAt": "2025-04-25", "@id": "71rqzxkebhkt", "@type": "Cycle", "description": "Aggregate cycle representing all 75 dairy farms sampled", "startDateDefinition": "one year prior", "endDate": "2019", "cycleDuration": 365, "functionalUnit": "relative", "functionalUnitDetails": "Per year of production from farms", "site": {"@type": "Site", "@id": "pbcn9hpkm_hz"}, "siteDuration": 272, "siteUnusedDuration": 93, "otherSites": [{"@type": "Site", "@id": "e1wdlb_oqa6s"}, {"@type": "Site", "@id": "wxyfbh4jgm_p"}], "otherSitesDuration": [46.5, 46.5], "otherSitesUnusedDuration": [318.5, 318.5], "otherSitesArea": [26.7, 4.5], "defaultSource": {"@id": "3tmw64utoxmb", "@type": "Source"}, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "Each farm was visited once by the same trained operator in a given region, each of whom used the same standardised questionnaire and procedure to minimize any operator-associated bias. The data collected to describe farm structure and management regarded housing (tie vs loose), manure management (slurry vs solid manure), manure storage (covered vs uncovered tank), calving management (seasonal vs non-seasonal), feeding (total mixed rations (TMR) vs traditional, i.e., forages administered ad libitum and concentrate supplements or part of forages administered in different amounts to each animal). We also recorded whether or not the farms used lowland pastures and practiced transhumance (i.e., movement of livestock to temporary units at high altitudes in summer to graze on Alpine grasslands), and, where relevant, the length of the grazing period. Off-farm feedstuffs were purchased, so the amount of each purchased feedstuff was known from the commercial invoices.", "inputs": [{"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "