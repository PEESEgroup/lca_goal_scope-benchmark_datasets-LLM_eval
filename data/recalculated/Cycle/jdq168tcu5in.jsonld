{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2023-09-28", "updatedAt": "2025-04-25", "@id": "jdq168tcu5in", "@type": "Cycle", "description": "North Italy Representative Farms - embodying the average dairy farms in Northern Italy present in the Po plain that make milk for Grana Padano cheese production. The cattle feed was based on silage feed (primarily corn silage), forage, protein ingredients (such as soybean meal), corn cereals, alfalfa, and compound feed. In this farm system, cattle were not allowed to graze.", "endDate": "2019", "cycleDuration": 365, "startDateDefinition": "one year prior", "functionalUnit": "relative", "site": {"@type": "Site", "@id": "otrdoo430x42"}, "defaultSource": {"@id": "jix42tsxvioy", "@type": "Source"}, "dataPrivate": false, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "The surveys were conducted by compiling a questionnaire with farmers, and data collected referred to one year of production. The questionnaire for the Dairy Farm collected activity data on farm characteristics, input, milk productivity and feed management system, including crop production and feed choices (type and quantity of crop cultivated, type and quantity of purchased feed, presence of silage).", "inputs": [{"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "units": "kWh"}, "value": [56308], "min": [5063], "max": [308087], "statsDefinition": "cycles", "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [22837.569], "min": [1525.784], "max": [82341.419], "statsDefinition": "cycles", "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Liquefied petroleum gases (LPG)", "units": "kg", "@id": "liquefiedPetroleumGasesLpg"}, "value": [1022.497], "min": [0], "max": [37406.026], "statsDefinition": "cycles", 