{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2023-09-28", "updatedAt": "2025-04-25", "@id": "w7bff-y5wzbj", "@type": "Cycle", "description": "Mountainous Farms - representative of farms located in Alpine mountain areas that produce milk destined for the Trentingrana cheese making. For this farm system, silage feed was not allowed. The cattle were fed without silage feed and protein ingredients, but mainly with forage and compound feed, with small amounts of alfalfa and corn feed. The herd grazed for four months during the summer season, except for the calves.", "endDate": "2019", "cycleDuration": 365, "startDateDefinition": "one year prior", "functionalUnit": "relative", "site": {"@type": "Site", "@id": "dfhm030cs0b1"}, "defaultSource": {"@id": "jix42tsxvioy", "@type": "Source"}, "dataPrivate": false, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "The surveys were conducted by compiling a questionnaire with farmers, and data collected referred to one year of production. The questionnaire for the Dairy Farm collected activity data on farm characteristics, input, milk productivity and feed management system, including crop production and feed choices (type and quantity of crop cultivated, type and quantity of purchased feed, presence of silage).", "inputs": [{"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "units": "kWh"}, "value": [6978], "min": [3869], "max": [9573], "statsDefinition": "cycles", "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [2740.025], "min": [881.986], "max": [6061.712], "statsDefinition": "cycles", "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Liquefied petroleum gases (LPG)", "units": "kg", "@id": "liquefiedPetroleumGasesLpg"}, "value": [86.821], "min": [0], "max": [34