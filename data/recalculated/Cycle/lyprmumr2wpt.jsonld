{"@context": "https://contribute.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-02-09", "updatedAt": "2025-04-25", "@id": "lyprmumr2wpt", "@type": "Cycle", "description": "Annual cycle of an alternative cow-calf production system in the Charolais basin, in which cattle are fed wrapped grass silage, in order to increase their omega-3 fatty acid intake. This consists of three components: 1) Reproduction, output of which = weaned male calves, weaned female calves not used for replacement cull cows, cull cows and a breeding bull. 2) Rearing female calves from weaning (9 months) to finishing at 33 months. 3) Finishing of cull cows, i.e. fattened before sending to the slaughterhouse. Both St and O3 are classified as extensive systems with 7.5 months grazing from April to November. The grazed area consists of 88% permanent versus 12% temporary grassland - this has been used to calculate the relative time spent on permanent versus temporary grassland during those 7.5 months of grazing.", "startDateDefinition": "one year prior", "endDate": "2010", "cycleDuration": 365, "functionalUnit": "relative", "site": {"@type": "Site", "@id": "rtrs8u9-j8xd"}, "siteDuration": 201, "siteUnusedDuration": 164, "siteArea": 45.1, "otherSites": [{"@type": "Site", "@id": "jz7lt-giovpn"}, {"@type": "Site", "@id": "fnngfxdbpga9"}], "otherSitesDuration": [137, 27], "otherSitesUnusedDuration": [228, 338], "defaultSource": {"@id": "2uaxgmjzmtai", "@type": "Source"}, "defaultMethodClassification": "modelled", "defaultMethodClassificationDescription": "As suckler-cow farming practices in the Charolais basin are highly diverse, our systems were modelled based on “Charolais Beef Cattle Farm Networks” of the French Livestock Institute (Réseaux d'élevage Charolais, 2009) in consultation with beef researchers and experts.", "practices": [{"term": {"@type": "Term", "name": "Charolais", "termType": "animalBreed", "@id": "charolais", "units": "%"}, "value": [100], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Stocking density, permanent pasture (average)", "termType": "animalManagement", "@id": "stockingDensityPermanentPastureAverage", "units": "animals / m2"}, "value": [0.000401330376940133], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Study gives 1.2 LU/ha and that 1 LU consumed 5t fresh forage per year. Used these to work out the DMI/hectare of forage per year. Using the DMI of forage per year (total of values provided for each category of animals), we worked out the no. hectares grazing area. Then separately totalled all of the average no.s of animals in each category in the herd, and divided this total by the no. hectares. Assumption is that the 5t DMI intake per year is referring only to the grazed grass (and not the total of all types of feeds). If the latter, the calculated stocking density would be lower (see tab 3 of upload file to compare).", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Pasture grass", "termType": "landUseManagement", "@id": "pastureGrass", "units": "% area"}, "key": {"@type": "Term", "termType": "landCover", "name": "Generic grass plant", "units": "% area", "@id": "genericGrassPlant"}, "value": [100], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Confined pasture system", "termType": "system", "@id": "confinedPastureSystem", "units": "% area"}, "value": [62.465753424657535], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Indoor animal system", "termType": "system", "@id": "indoorAnimalSystem", "units": "% area"}, "value": [37.534246575342465], "@type": "Practice"}, {"@type": "Practice", "term": {"@type": "Term", "@id": "croppingIntensity", "name": "Cropping intensity", "termType": "landUseManagement", "units": "ratio"}, "site": {"@type": "Site", "@id": "fnngfxdbpga9"}, "value": [0.9960058], "added": ["term", "site", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"@type": "Practice", "term": {"@type": "Term", "@id": "unknownPreSeasonWaterRegime", "name": "Unknown pre-season water regime", "termType": "landUseManagement", "units": "% area"}, "model": {"@type": "Term", "@id": "hestia", "name": "HESTIA", "termType": "model"}, "value": [100], "added": ["term", "model", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"@type": "Practice", "term": {"@type": "Term", "@id": "stockingDensityAnimalHousingAverage", "name": "Stocking density, animal housing (average)", "termType": "animalManagement", "units": "animals / m2"}, "model": {"@type": "Term", "@id": "hestia", "name": "HESTIA", "termType": "model"}, "value": [0.3231852], "added": ["term", "model", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"@type": "Practice", "term": {"@type": "Term", "@id": "longFallowRatio", "name": "Long fallow ratio", "termType": "landUseManagement", "units": "ratio"}, "site": {"@type": "Site", "@id": "fnngfxdbpga9"}, "value": [1.0293495], "added": ["term", "site", "value"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}], "animals": [{"term": {"@type": "Term", "termType": "liveAnimal", "name": "Beef cattle, cow", "units": "number", "@id": "beefCattleCow"}, "animalId": "Cows", "value": 70, "referencePeriod": "average", "inputs": [{"term": {"@type": "Term", "name": "Generic grass, fresh forage", "termType": "forage", "@id": "genericGrassFreshForage", "units": "kg"}, "value": [179343.08256577782], "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 100, "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "acidDetergentFibreContent", "name": "Acid detergent fibre content", "termType": "property", "units": "%"}, "value": 38.15, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "ashContent", "name": "Ash content", "termType": "property", "units": "%"}, "value": 9.98, "added": ["term", "value"], "addedVersion": [