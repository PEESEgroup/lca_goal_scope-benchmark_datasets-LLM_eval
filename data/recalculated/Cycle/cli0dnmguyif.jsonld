{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-04-17", "updatedAt": "2025-04-25", "@id": "cli0dnmguyif", "@type": "Cycle", "description": "Aggregate cycle representing data from 4 farms in Zona da mata, Minas Gerais in 2019, all producing milk under a semi-confinement system, where animals spend part of each day on pasture, and the remainder confined", "endDate": "2019", "functionalUnit": "relative", "functionalUnitDetails": "1 kg FPCM", "site": {"@type": "Site", "@id": "suiath2bgsqr"}, "otherSites": [{"@type": "Site", "@id": "uncoi5gmnahs"}], "defaultSource": {"@id": "v9neu-ph4e_r", "@type": "Source"}, "defaultMethodClassification": "verified survey data", "defaultMethodClassificationDescription": "A structured questionnaire was created. The questionnaire was previously tested through interviews with specialists in the area to certify the consistency of the questions and the compliance with the data quality criteria.  Most of the data provided in the inventories is primary, collected in the field, through on-site interviews with farm owners and managers and expert technical consultants from the agro-industrial cooperative. After completion, the three inventories were sent for external review, where 5 specialists critically provided feedback on the inventories. After such review, the inventories were submitted to the SICV/Brazil. The external review was carried out by five professionals trained in both LCA and milk production who do not belong to the team who conducted this study and the reviewers did not report any known conflict of interest related to reviewing those inventories.", "inputs": [{"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [0.023624979020784267], "@type": "Input"}, {"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "units": "kWh"}, "value": [0.04414492008264847], "@type": "Input"}, {"term": {"@type": "Term", "termType": "water", "name": "Water, river/stream", "units": "m3", "@id": "waterRiverStream"}, "value": [0.007430923397932817], "operation": {"@type": "Term", "name": "Providing animals with water", "termType": "operation", "@id": "providingAnimalsWithWater", "units": "hour"}, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Maize, silage", "units": "kg", "@id": "maizeSilage"}, "value": [0.7571524492183322], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Elephant grass, silage", "units": "kg", "@id": "elephantGrassSilage"}, "value": [0.20280869175491045], "description": "\"Capiaçu\" silage", "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Maize, gluten meal", "units": "kg", "@id": "maizeGlutenMeal"}, "value": [0.3008932312085118], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Soybean, meal", "units": "kg", "@id": "soybeanMeal"}, "value": [0.13234640989066634], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Sodium chloride", "termType": "feedFoodAdditive", "@id": "sodiumChloride", "units": "kg"}, "value": [0.005318819982773471], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Cotton, meal (unspecified)", "units": "kg", "@id": "cottonMealUnspecified"}, "value": [0.04266799392143675], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Nitrogen fertiliser, unspecified (kg N)", "termType": "inorganicFertiliser", "@id": "inorganicNitrogenFertiliserUnspecifiedKgN", "units": "kg N"}, "value": [0.00837218404120208], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Phosphorus fertiliser, unspecified (kg P2O5)", "termType": "inorganicFertiliser", "@id": "inorganicPhosphorusFertiliserUnspecifiedKgP2O5", "units": "kg P2O5"}, "value": [0.002