{"@context": "https://contribute.hestia.earth/schema/Cycle.jsonld", "createdAt": "2025-03-10", "updatedAt": "2025-04-25", "@id": "we8vze7ekgou", "@type": "Cycle", "description": "Crop-livestock rotation system", "treatment": "Crop rotation occurs every four years. The pasture area (780 ha) was divided into eight plots of 97.5 ha, four plots (390 ha) for pasture, and four plots (390 ha) for grain planting. Annually, one pasture plot is destined to planting grains, while a field previously used for grain planting returns to pasture activity. In this way, crop rotation occurs in all fields of the farm every four years.", "commercialPracticeTreatment": true, "endDate": "2017", "functionalUnit": "relative", "site": {"@type": "Site", "@id": "uc4wqpdukzue"}, "defaultSource": {"@id": "evw50pucedpe", "@type": "Source"}, "defaultMethodClassification": "modelled", "defaultMethodClassificationDescription": "Data were collected from eleven farms in the municipalities of Itaquiraí-MS, Naviraí-MS, Iguatemi-MS, Amambai-MS and Jateí-MS between November and December 2017. Due to variability and local characteristics that may directly affect the results, a modeling of the production systems was carried out so that it is possible to establish that the compared systems have the same area and the same soil and climatic characteristics.", "inputs": [{"term": {"@type": "Term", "termType": "feedFoodAdditive", "name": "Minerals, unspecified", "units": "kg", "@id": "mineralsUnspecified"}, "value": [18954], "transport": [{"term": {"@type": "Term", "termType": "transport", "name": "Freight, lorry, light commercial vehicle", "units": "tkm", "@id": "freightLorryLightCommercialVehicle"}, "distance": 272, "returnLegIncluded": false, "@type": "Transport"}], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Soybean, protein concentrate", "termType": "processedFood", "@id": "soybeanProteinConcentrate", "units": "kg"}, "value": [23790], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Assumed the protein was soybean.", "properties": [{"term": {"@type": "Term", "name": "Crude protein content", "termType": "property", "@id": "crudeProteinContent", "units": "%"}, "value": 35, "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Have assumed crude protein content for the protein supplement.", "share": 100, "@type": "Property"}], "isAnimalFeed": true, "@type": "Input"}, {"@type": "Input", "term": {"@type": "Term", "@id": "breadGrassFreshForage", "name": "Bread grass, fresh forage", "termType": "forage", "units": "kg"}, "model": {"@type": "Term", "@id": "ipcc2019", "name": "IPCC (2019)", "termType": "model"}, "value": [13756933.491746647], "isAnimalFeed": true, "added": ["term", "model", "value", "isAnimalFeed"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0", "0.70.0"]}], "practices": [{"term": {"@type": "Term", "termType": "operation", "name": "Ploughing, machine unspecified", "units": "hour", "@id": "ploughingMachineUnspecified"}, "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Liming on bed", "units": "hour", "@id": "limingOnBed"}, "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Sowing or planting, machine unspecified", "units": "hour", "@id": "sowingOrPlantingMachineUnspecified"}, "@type": "Practice"}, {"term": {"@type": "Term", "name": "Rotational grazing", "termType": "landUseManagement", "@id": "rotationalGrazing", "units": "% area"}, "value": [100], "@type": "Practice"}, {"term": {"@type": "Term", "name": "Pasture grass", "termType": "landUseManagement", "@id": "pastureGrass", "units": "% area"}, "key": {"@type": "Term", "termType": "landCover", "name": "Bread grass plant", "units": "% area", "@id": "breadGrassPlant"}, "value": [100], "@type": "Practice"}, {"term": {"@type": "Term", "termType": "operation", "name": "Fertilising, machine unspecified", "units": "hour", "@id": "fertilisingMac