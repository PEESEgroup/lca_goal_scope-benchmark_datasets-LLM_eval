{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-05-08", "updatedAt": "2025-04-25", "@id": "3oc-ypbsafu5", "@type": "Cycle", "startDateDefinition": "one year prior", "endDate": "2019", "cycleDuration": 365, "functionalUnit": "1 ha", "numberOfCycles": 251, "site": {"@type": "Site", "@id": "fbfx9yj0tdz3"}, "siteDuration": 365, "siteUnusedDuration": 0, "defaultSource": {"@id": "8hyob7obzdci", "@type": "Source"}, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "The information used in this study was obtained from the Sustainable Colombian Cattle Ranching (GCS, Spanish initials) and the LivestockPlus (L+) projects conducted in Colombia. In these studies, over a period of 1 year, quantitative and qualitative data were collected by applying surveys on farms.", "inputs": [{"term": {"@type": "Term", "name": "Inorganic Nitrogen fertiliser, unspecified (kg N)", "termType": "inorganicFertiliser", "@id": "inorganicNitrogenFertiliserUnspecifiedKgN", "units": "kg N"}, "value": [9.145], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Phosphorus fertiliser, unspecified (kg P2O5)", "termType": "inorganicFertiliser", "@id": "inorganicPhosphorusFertiliserUnspecifiedKgP2O5", "units": "kg P2O5"}, "value": [5.405161290322581], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Potassium fertiliser, unspecified (kg K2O)", "termType": "inorganicFertiliser", "@id": "inorganicPotassiumFertiliserUnspecifiedKgK2O", "units": "kg K2O"}, "value": [2.8441025641025637], "@type": "Input"}, {"term": {"@type": "Term", "name": "Dolomitic lime", "termType": "soilAmendment", "@id": "dolomiticLime", "units": "kg CaMg(CO3)2"}, "value": [22], "@type": "Input"}, {"term": {"@type": "Term", "name": "Concentrate feed, unspecified", "termType": "processedFood", "@id": "concentrateFeedUnspecified", "units": "kg"}, "value": [70.76], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Sugarcane, molasses", "units": "kg", "@id": "sugarcaneMolasses"}, "value": [34.769999999999996], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "feedFoodAdditive", "name": "Minerals, unspecified", "units": "kg", "@id": "mineralsUnspecified"}, "value": [39.284000000000006], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [0.82848], "@type": "Input"}, {"term": {"@type": "Term", "name": "Lime", "termType": "soilAmendment", "@id": "lime", "units": "kg CaCO3"}, "value": [17], "@type": "Input"}, {"term": {"@type": "Term", "name": "Generic grass, fresh forage", "termType": "forage", "@id": "genericGrassFreshForage", "units": "kg"}, "isAnimalFeed": true, "producedInCycle": true, "value": [2910.0239043824704], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "The total DMI for the farm is 117.9 tonnes. The average percentage of DMI coming from external feed is 3% (this was calculated as a weighted average across all farms from Table 8 in the study). This leaevs 97% DMI coming from forage. So the value here was calculated as Total DMI * 97%.", "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 100, "share": 100, "@type": "Property"}, {"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 34.7250967072189, "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Gross Energy was given in the study. From this we took away the total Energy from external feeds (assuming an energy density of 18.45 which was given in the study). This gave us a value for MJ coming from forage, which we divided by the total quantity of forage consumed in DM. Therefore this energy content property represents the energy density of the fresh forage in MJ per kg of DM.", "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "acidDetergentFibreContent", "name": "Acid detergent fibre content", "termType": "property", "units": "%"}, "value": 38.15, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "ashContent", "name": "Ash content", "termType": "property", "units": "%"}, "value": 9.98, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "calciumContent", "name": "Calcium content", "termType": "property", "units": "%"}, "value": 0.58, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "copperContent", "name": "Copper content", "termType": "property", "units": "%"}, "value": 0.0, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "crudeFibreContent", "name": "Crude fibre content", "termType": "property", "units": "%"}, "value": 32.36, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Ter