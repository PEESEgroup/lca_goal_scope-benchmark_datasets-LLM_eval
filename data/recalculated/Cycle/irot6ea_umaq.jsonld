{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-05-08", "updatedAt": "2025-04-25", "@id": "irot6ea_umaq", "@type": "Cycle", "startDateDefinition": "one year prior", "endDate": "2019", "cycleDuration": 365, "functionalUnit": "1 ha", "numberOfCycles": 275, "site": {"@type": "Site", "@id": "ukrhvlpkedue"}, "siteDuration": 365, "siteUnusedDuration": 0, "defaultSource": {"@id": "8hyob7obzdci", "@type": "Source"}, "defaultMethodClassification": "non-verified survey data", "defaultMethodClassificationDescription": "The information used in this study was obtained from the Sustainable Colombian Cattle Ranching (GCS, Spanish initials) and the LivestockPlus (L+) projects conducted in Colombia. In these studies, over a period of 1 year, quantitative and qualitative data were collected by applying surveys on farms.", "inputs": [{"term": {"@type": "Term", "name": "Inorganic Nitrogen fertiliser, unspecified (kg N)", "termType": "inorganicFertiliser", "@id": "inorganicNitrogenFertiliserUnspecifiedKgN", "units": "kg N"}, "value": [14.446], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Phosphorus fertiliser, unspecified (kg P2O5)", "termType": "inorganicFertiliser", "@id": "inorganicPhosphorusFertiliserUnspecifiedKgP2O5", "units": "kg P2O5"}, "value": [8.538322580645163], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Potassium fertiliser, unspecified (kg K2O)", "termType": "inorganicFertiliser", "@id": "inorganicPotassiumFertiliserUnspecifiedKgK2O", "units": "kg K2O"}, "value": [4.4927179487179485], "@type": "Input"}, {"term": {"@type": "Term", "name": "Dolomitic lime", "termType": "soilAmendment", "@id": "dolomiticLime", "units": "kg CaMg(CO3)2"}, "value": [33], "@type": "Input"}, {"term": {"@type": "Term", "name": "Concentrate feed, unspecified", "termType": "processedFood", "@id": "concentrateFeedUnspecified", "units": "kg"}, "value": [386.22], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Sugarcane, molasses", "units": "kg", "@id": "sugarcaneMolasses"}, "value": [263.603], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "feedFoodAdditive", "name": "Minerals, unspecified", "units": "kg", "@id": "mineralsUnspecified"}, "value": [55.578], "isAnimalFeed": true, "properties": [{"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 18.45, "share": 100, "@type": "Property"}], "@type": "Input"}, {"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [1.1995699999999998], "@type": "Input"}, {"term": {"@type": "Term", "termType": "liveAnimal", "name": "Beef cattle, calf (weaned)", "units": "number", "@id": "beefCattleCalfWeaned"}, "isAnimalFeed": false, "description": "Lack of reliable information on animal fluxes in Colombia due to lack of record-keeping by farmers, poor integration between cow-calf and fattening systems, intermediary market actors, animal smuggling and illegal slaughterhouses.", "@type": "Input"}, {"term": {"@type": "Term", "name": "Lime", "termType": "soilAmendment", "@id": "lime", "units": "kg CaCO3"}, "value": [12], "@type": "Input"}, {"term": {"@type": "Term", "name": "Generic grass, fresh forage", "termType": "forage", "@id": "genericGrassFreshForage", "units": "kg"}, "isAnimalFeed": true, "producedInCycle": true, "value": [2935.7729126213585], "methodClassification": "estimated with assumptions", "methodClassificationDescription": "The total DMI for the farm is 117.9 tonnes. The average percentage of DMI coming from external feed was calculated as a weighted average across all farms from Table 8 in the study. This leavs x% DMI coming from forage. So the value here was calculated as Total DMI * x%.", "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 100, "share": 100, "@type": "Property"}, {"term": {"@type": "Term", "name": "Energy content (higher heating value)", "termType": "property", "@id": "energyContentHigherHeatingValue", "units": "MJ / kg"}, "value": 34.7250967072189, "methodClassification": "estimated with assumptions", "methodClassificationDescription": "Gross Energy was given in the study. From this we took away the total Energy from external feeds (assuming an energy density of 18.45 which was given in the study). This gave us a value for MJ coming from forage, which we divided by the total quantity of forage consumed in DM. Therefore this energy content property represents the energy density of the fresh forage in MJ per kg of DM.", "share": 100, "@type": "Property"}, {"@type": "Property", "term": {"@type": "Term", "@id": "acidDetergentFibreContent", "name": "Acid detergent fibre content", "termType": "property", "units": "%"}, "value": 38.15, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "ashContent", "name": "Ash content", "termType": "property", "units": "%"}, "value": 9.98, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "calciumContent", "name": "Calcium content", "termType": "property", "units": "%"}, "value": 0.58, "added": ["term", "value"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Property", "term": {"@type": "Term", "@id": "copperContent", "name": "Cop