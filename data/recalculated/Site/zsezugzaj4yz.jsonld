{"@context": "https://www-staging.hestia.earth/schema/Site.jsonld", "createdAt": "2024-04-17", "updatedAt": "2025-05-22", "@id": "zsezugzaj4yz", "@type": "Site", "defaultSource": {"@id": "v9neu-ph4e_r", "@type": "Source"}, "siteType": "permanent pasture", "country": {"@type": "Term", "@id": "GADM-BRA", "name": "Brazil", "termType": "region"}, "region": {"@type": "Term", "termType": "region", "name": "Paraná (Estado), Brazil", "@id": "GADM-BRA.16_1"}, "boundary": {"type": "FeatureCollection", "features": [{"type": "Feature", "properties": {}, "geometry": {"type": "Polygon", "coordinates": [[[-50.51011097930439, -25.33302257882301], [-49.87290394805439, -25.362808431260873], [-49.56528676055439, -25.104421246780145], [-49.49936879180439, -24.70583563332567], [-49.53232777617939, -24.476068420200626], [-50.08164418242939, -24.356022873779036], [-50.67490590117939, -24.33600419104649], [-51.19126332305439, -24.546042190912207], [-51.16929066680439, -24.885358444659577], [-50.83970082305439, -25.273428883540763], [-50.51011097930439, -25.33302257882301]]]}}]}, "numberOfSites": 4, "area": 21.85350060704168, "defaultMethodClassification": "verified survey data", "defaultMethodClassificationDescription": "A structured questionnaire was created. The questionnaire was previously tested through interviews with specialists in the area to certify the consistency of the questions and the compliance with the data quality criteria.  Most of the data provided in the inventories is primary, collected in the field, through on-site interviews with farm owners and managers and expert technical consultants from the agro-industrial cooperative. After completion, the three inventories were sent for external review, where 5 specialists critically provided feedback on the inventories. After such review, the inventories were submitted to the SICV/Brazil. The external review was carried out by five professionals trained in both LCA and milk production who do not belong to the team who conducted this study and the reviewers did not report any known conflict of interest related to reviewing those inventories.", "management": [{"term": {"@type": "Term", "@id": "improvedPasture", "name": "Improved pasture", "termType": "pastureManagement", "units": "% area"}, "value": 100, "endDate": "2019", "@type": "Management"}], "dataPrivate": false, "name": "Permanent pasture - Paraná (Estado), Brazil", "boundaryArea": 1594705.3030832151, "schemaVersion": "30.5.0", "originalId": "MPS 2 Pasture", "measurements": [{"@type": "Measurement", "term": {"@type": "Term", "@id": "ecoClimateZone", "name": "Eco-Climate Zone", "termType": "measurement", "units": "categorical"}, "description": "Tropical Moist", "value": [11], "methodClassification": "geospatial dataset", "source": {"@type": "Source", "@id": "f3uds1istj0r", "name": "Hiederer et al (2010)"}, "added": ["term", "description", "value", "methodClassification", "source"], "addedVersion": ["0.70.3", "0.70.3", "0.70.3", "0.70.3", "0.70.3"]}], "added": ["measurements"], "addedVersion": ["0.70.3"]}