      "term": {
        "@type": "Term",
        "termType": "liveAnimal",
        "name": "Layer chicken, hen",
        "units": "number",
        "@id": "layerChickenHen"
      },
      "animalId": "1",
      "referencePeriod": "average",
      "value": 33.98038462,
      "min": 31.68538462,
      "max": 37.58961538,
      "statsDefinition": "cycles",
      "methodClassification": "estimated with assumptions",
      "methodClassificationDescription": "The study does not specify how old the pullets are at the start of the laying cycle. We have assumed that they are young pullets and so do not start producing eggs until they are 18 weeks old. Therefore, we have calculated the number of hens using this assumption of the pullets, where of the total number of pullets in the laying cycle (which has been scaled to 1 year), 18/52*number of pullets in study is equal to the number of pullets in this upload. 34/52*number of pullets in the study is equal to the number of hens.",
      "@type": "Animal"
    }
  ],
