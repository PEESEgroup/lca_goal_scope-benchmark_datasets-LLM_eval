  "animals": [
    {
      "animalId": "Cows",
      "term": {
        "@type": "Term",
        "termType": "liveAnimal",
        "name": "Dairy cattle, cow",
        "units": "number",
        "@id": "dairyCattleCow"
      },
      "referencePeriod": "average",
      "value": 24,
      "methodClassification": "modelled",
      "methodClassificationDescription": "The herd size and composition were modelled on the basis of the mean number of cows, number of lactations (LacN), calving interval (CI), age at first calving and dry period length (DP). Derived from Berton et al., 2020",
      "properties": [
        {
          "term": {
            "@type": "Term",
            "name": "Liveweight per head",
            "termType": "property",
            "@id": "liveweightPerHead",
            "units": "kg liveweight / head"
          },
          "value": 587,
          "methodClassification": "modelled",
          "methodClassificationDescription": "The body weight (BW) of replacement heifers and dairy cows was computed as follows: BW of the heifers at the age of first calving was assumed as 82% of mean culled cows’ BW (NRC, 2001), which was collected during the farm visit. Consequently, mean dairy cows BW was computed as the mean between culled cows and heifers at the age of first calving, weighed by the number of primiparous and dairy cows. Number of primiparous cows was equal to the number of culled cows, assuming a constant herd size.",
          "share": 100,
          "@type": "Property"
        }
      ],
      "@type": "Animal"
    },
    {
      "animalId": "DryCows",
      "term": {
        "@type": "Term",
        "termType": "liveAnimal",
        "name": "Dairy cattle, cow (dry)",
        "units": "number",
        "@id": "dairyCattleCowDry"
      },
      "referencePeriod": "average",
      "value": 4,
      "methodClassification": "modelled",
      "methodClassificationDescription": "The herd size and composition were modelled on the basis of the mean number of cows, number of lactations (LacN), calving interval (CI), age at first calving and dry period length (DP). Derived from Berton et al., 2020",
      "@type": "Animal"
    },
    {
      "animalId": "OlderHeifers",
      "term": {
        "@type": "Term",
        "termType": "liveAnimal",
        "name": "Dairy cattle, heifer",
        "units": "number",
        "@id": "dairyCattleHeifer"
      },
      "referencePeriod": "average",
      "value": 3,
      "properties": [
        {
          "term": {
            "@type": "Term",
            "name": "Liveweight per head",
            "termType": "property",
            "@id": "liveweightPerHead",
            "units": "kg liveweight / head"
          },
          "value": 280,
          "methodClassification": "modelled",
          "methodClassificationDescription": "The body weight (BW) of replacement heifers and dairy cows was computed as follows: BW of the heifers at the age of first calving was assumed as 82% of mean culled cows’ BW (NRC, 2001), which was collected during the farm visit. The BW of the calf at birth was assumed 40 kg, and the mean BW of the replacement heifers was obtained as the mean between the BW at birth and the BW at the age of first calving",
          "share": 100,
