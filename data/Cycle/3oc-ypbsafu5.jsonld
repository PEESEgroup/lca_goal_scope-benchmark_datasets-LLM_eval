        {
          "term": {
            "@type": "Term",
            "name": "Energy content (higher heating value)",
            "termType": "property",
            "@id": "energyContentHigherHeatingValue",
            "units": "MJ / kg"
          },
          "value": 34.7250967072189,
          "methodClassification": "estimated with assumptions",
          "methodClassificationDescription": "Gross Energy was given in the study. From this we took away the total Energy from external feeds (assuming an energy density of 18.45 which was given in the study). This gave us a value for MJ coming from forage, which we divided by the total quantity of forage consumed in DM. Therefore this energy content property represents the energy density of the fresh forage in MJ per kg of DM.",
          "share": 100,
          "@type": "Property"
        }
      ],
      "@type": "Input"
    }
