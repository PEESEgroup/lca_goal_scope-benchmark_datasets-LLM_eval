{"@context":"https://www.hestia.earth/schema/Source.jsonld","createdAt":"2024-04-17","updatedAt":"2025-04-21","@id":"agdwd3nz8v0m","@type":"Source","dataPrivate":false,"originalLicense":"no public license","bibliography":{"documentDOI":"10.1016/j.jclepro.2020.123046","title":"Investigating on the environmental sustainability of animal products: The case of organic eggs","name":"Costantini et al (2020)","authors":[{"@id":"5f1xqw2ffggp","@type":"Actor"},{"@id":"4p1b35bgdhgk","@type":"Actor"},{"@id":"qgwltbu1ob4o","@type":"Actor"},{"@id":"kqb1vpfjnec9","@type":"Actor"},{"@id":"vdjpx1_kdzvn","@type":"Actor"},{"@id":"gf65aidcx0kw","@type":"Actor"},{"@id":"hqc4icebfqxj","@type":"Actor"},{"@id":"pk_mbv3na4bk","@type":"Actor"}],"outlet":"Journal of Cleaner Production","year":2020,"mendeleyID":"f55e60f6-aa5b-3cda-84ee-29e29b766d90","scopus":"2-s2.0-85088874872","@type":"Bibliography"},"uploadNotes":"The method used for the impact Assessment was “ the ILCD (International Reference Life Cycle Data System) 2011 Midpoint þ method (V1.03), which is the impact assessment method endorsed by the European Commission”. We used this link to figure out which models were used for the different impact categories: https://longtrailsustainability.com/wp-content/uploads/2016/10/ILCD-2011-Midpoint-is-the-PEF-Method.pdf","name":"Costantini et al (2020)","uploadBy":{"@type":"Actor","@id":"6230a4e702ca0d00133e2028"},"schemaVersion":"31.2.0","validationDate":"2025-04-21","validationBy":[{"@type":"Actor","@id":"6230a4e702ca0d00133e2028"}],"originalId":"1"}