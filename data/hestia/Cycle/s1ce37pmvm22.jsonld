  "defaultSource": {
    "@id": "2uaxgmjzmtai",
    "@type": "Source"
  },
  "defaultMethodClassification": "modelled",
  "defaultMethodClassificationDescription": "As suckler-cow farming practices in the Charolais basin are highly diverse, our systems were modelled based on “Charolais Beef Cattle Farm Networks” of the French Livestock Institute (Réseaux d'élevage Charolais, 2009) in consultation with beef researchers and experts.",
  "practices": [
    {
      "term": {
        "@type": "Term",
        "name": "Charolais",
        "termType": "animalBreed",
        "@id": "charolais",
        "units": "%"
      },
      "value": [
        100
      ],
      "@type": "Practice"
    },
    {
      "term": {
        "@type": "Term",
        "name": "Stocking density, permanent pasture (average)",
        "termType": "animalManagement",
        "@id": "stockingDensityPermanentPastureAverage",
        "units": "animals / m2"
      },
      "value": [
        0.0004037923993418313
      ],
      "methodClassification": "estimated with assumptions",
      "methodClassificationDescription": "Study gives 1.2 LU/ha and that 1 LU consumed 5t fresh forage per year. Used these to work out the DMI/hectare of forage per year. Using the DMI of forage per year (total of values provided for each category of animals), we worked out the no. hectares grazing area. Then separately totalled all of the average no.s of animals in each category in the herd, and divided this total by the no. hectares. Assumption is that the 5t DMI intake per year is referring only to the grazed grass (and not the total of all types of feeds). If the latter, the calculated stocking density would be lower (see tab 3 of upload file to compare).",
      "@type": "Practice"
    },
