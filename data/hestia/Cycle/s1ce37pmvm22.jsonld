{
  "@context": "https://contribute.hestia.earth/schema/Cycle.jsonld",
  "createdAt": "2024-02-09",
  "updatedAt": "2025-03-10",
  "@id": "s1ce37pmvm22",
  "@type": "Cycle",
  "description": "Annual cycle of the standard cow-calf production system in the Charolais basin. This consists of four components: 1) Reproduction, output of which = weaned male calves, weaned female calves not used for replacement, cull cows and a breeding bull. 2) Rearing female calves from weaning (9 months) to finishing at 33 months. 3) Finishing of cull cows, i.e. fattened before sending to the slaughterhouse. 4) Pre-fattening of male calves for 2 months after weaning (before being sent to a separate finishing farm). Both St and O3 are classified as extensive systems with 7.5 months grazing from April to November. The grazed area consists of 88% permanent versus 12% temporary grassland - this has been used to calculate the relative time spent on permanent versus temporary grassland during those 7.5 months of grazing.",
  "startDateDefinition": "one year prior",
  "endDate": "2010",
  "cycleDuration": 365,
  "functionalUnit": "relative",
  "site": {
    "@id": "0ajwbol0bvvu",
    "@type": "Site"
  },
  "siteDuration": 201,
  "siteUnusedDuration": 164,
  "siteArea": 46.06666666666667,
