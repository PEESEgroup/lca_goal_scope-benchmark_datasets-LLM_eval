{
  "@context": "https://contribute.hestia.earth/schema/Cycle.jsonld",
  "createdAt": "2024-02-09",
  "updatedAt": "2025-03-10",
  "@id": "lyprmumr2wpt",
  "@type": "Cycle",
  "description": "Annual cycle of an alternative cow-calf production system in the Charolais basin, in which cattle are fed wrapped grass silage, in order to increase their omega-3 fatty acid intake. This consists of three components: 1) Reproduction, output of which = weaned male calves, weaned female calves not used for replacement cull cows, cull cows and a breeding bull. 2) Rearing female calves from weaning (9 months) to finishing at 33 months. 3) Finishing of cull cows, i.e. fattened before sending to the slaughterhouse. Both St and O3 are classified as extensive systems with 7.5 months grazing from April to November. The grazed area consists of 88% permanent versus 12% temporary grassland - this has been used to calculate the relative time spent on permanent versus temporary grassland during those 7.5 months of grazing.",
  "startDateDefinition": "one year prior",
  "endDate": "2010",
  "cycleDuration": 365,
  "functionalUnit": "relative",
  "site": {
    "@id": "rtrs8u9-j8xd",
    "@type": "Site"
  },
  "siteDuration": 201,
  "siteUnusedDuration": 164,
  "siteArea": 45.1,
