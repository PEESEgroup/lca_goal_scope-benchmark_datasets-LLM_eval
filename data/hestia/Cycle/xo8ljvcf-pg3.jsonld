{"@context":"https://www.hestia.earth/schema/Cycle.jsonld","createdAt":"2024-04-17","updatedAt":"2025-04-21","@id":"xo8ljvcf-pg3","@type":"Cycle","description":"Organic farm production of eggs. Flock spends daylight hours outdoors in free-range area (site 2), but are housed in the barn overnight.","startDateDefinition":"stocking date","endDate":"2019","cycleDuration":504,"functionalUnit":"relative","functionalUnitDetails":"Quantity of eggs produced in a full laying cycle (72 weeks) for a batch of 3000 laying hens","site":{"@id":"mcdozkymt6r2","@type":"Site"},"otherSites":[{"@id":"xhd5rbygulof","@type":"Site"}],"defaultSource":{"@id":"agdwd3nz8v0m","@type":"Source"},"defaultMethodClassification":"non-verified survey data","defaultMethodClassificationDescription":"Data collected through a survey at the farm and a questionnaire completed by the farmer.","inputs":[{"term":{"@type":"Term","termType":"liveAnimal","name":"Layer chicken, pullet","units":"number","@id":"layerChickenPullet"},"value":[3000],"description":"Raised with organic method in another specialised farm located in the neighbouring region","impactAssessment":{"@id":"_ahbr3_snx9b","@type":"ImpactAssessment"},"impactAssessmentIsProxy":false,"isAnimalFeed":false,"properties":[{"term":{"@type":"Term","name":"Age","termType":"property","@id":"age","units":"days"},"value":112,"share":100,"@type":"Property"},{"term":{"@type":"Term","name":"Liveweight per head","termType":"property","@id":"liveweightPerHead","units":"kg liveweight / head"},"value":1.55,"share":100,"@type":"Property"},{"term":{"@type":"Term","name":"Organic (property)","termType":"property","@id":"organicProperty","units":"%"},"value":100,"share":100,"@type":"Property"}],"@type":"Input"},{"term":{"@type":"Term","name":"Sand (material)","termType":"material","@id":"sandMaterial","units":"kg"},"value":[3200],"@type":"Input"},{"term":{"@type":"Term","name":"Concentrate feed blend","termType":"processedFood","@id":"concentrateFeedBlend","units":"kg"},"isAnimalFeed":true,"value":[64209.6],"impactAssessment":{"@id":"pfek9kvmjpnn","@type":"ImpactAssessment"},"impactAssessmentIsProxy":false,"description":"The feed provided for the first 24 weeks of the laying cycle (Feed Blend 1). Quantity takes into account \"an additional 2.5% was considered compared to the average ani- mals’ intake, due to wastes declared by the farmer that occur during animal feeding. This share of spilled feed falls to the ground and mixes with litter material and animal excreta, contributing to manure formation.\" - from study","@type":"Input"},{"term":{"@type":"Term","name":"Electricity, grid, market mix","termType":"electricity","@id":"electricityGridMarketMix","units":"kWh"},"value":[11250],"description":"The amount of electricity consumed per year converted to amount of electrcity consumed across the cycle per head.","@type":"Input"},{"term":{"@type":"Term","termType":"water","name":"Water, source unspecified","units":"m3","@id":"waterSourceUnspecified"},"value":[378],"description":"Amount of water consumed per day converted to amount of water consumed across the cycle per head.","@type":"Input"},{"term":{"@type":"Term","name":"Concentrate feed blend","termType":"processedFood","@id":"concentrateFeedBlend","units":"kg"},"isAnimalFeed":true,"value":[128419.2],"impactAssessment":{"@id":"epnbimwkyv8c","@type":"ImpactAssessment"},"impactAssessmentIsProxy":false,"description":"The feed provided for the latter 48 weeks of the laying cycle (Feed Blend 2). Quantity takes into account \"an additional 2.5% was considered compared to the average ani- mals’ intake, due to wastes declared by the farmer that occur during animal feeding. This share of spilled feed falls to the ground and mixes with litter material and animal excreta, contributing to manure formation.\" - from study","@type":"Input"}],"practices":[{"term":{"@type":"Term","name":"Pasture grass","termType":"landUseManagement","@id":"pastureGrass","units":"% area"},"key":{"@type":"Term","ter