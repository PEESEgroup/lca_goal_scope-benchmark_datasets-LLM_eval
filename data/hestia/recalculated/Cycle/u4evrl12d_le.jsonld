{"@context": "https://www.hestia.earth/schema/Cycle.jsonld", "createdAt": "2023-12-12", "updatedAt": "2025-04-25", "@id": "u4evrl12d_le", "@type": "Cycle", "description": "Cycle represents all inputs associated with the rearing of all chicks, pullets and layer hens in order to produce 1000kg of eggs in organic free range systems.", "endDate": "2010", "cycleDuration": 504, "startDateDefinition": "start of animal life", "functionalUnit": "relative", "functionalUnitDetails": "1000kg of eggs produced", "site": {"@type": "Site", "@id": "x1icgv7ippzz"}, "defaultSource": {"@id": "fwy8ntyofqew", "@type": "Source"}, "defaultMethodClassification": "modelled", "defaultMethodClassificationDescription": "The structural model calculated all of the inputs required to produce the functional unit, allowing for breeding overheads (3 generations of breeding stock), mortalities, and productivity levels. The general structure of the model was based on multiple linear equations, which were solved simultane- ously with a code written in Visual Basic for applications specifically for this purpose. A mechanistic animal growth and production model was used in the current study for 3 purposes: 1) to calculate the total consumption of each feed ingredient during the whole production cycle; 2) to calculate the amounts of main nutrients, N, P, and K, in manure pro- duced by the birds during the production cycle; and 3) to include the correlation between changes in the pro- duction figures (egg production, feed intake, and nutri- ent output) to be applied in the uncertainty analysis (see below). The model was based on the principles pre- sented by Emmans and Kyriazakis (2001) and Wellock et al. (2003), and predicted the daily feed intake, which varies considerably during the bird life cycle, of a single bird as a function of feed composition and energy and protein requirements of the bird. This included require- ments for both production (body growth and eggs) and maintenance.", "treatment": "Organic", "commercialPracticeTreatment": true, "numberOfReplications": 1, "inputs": [{"term": {"@type": "Term", "name": "Feed mix", "termType": "processedFood", "@id": "feedMix", "units": "kg"}, "value": [257.91666666666663], "impactAssessment": {"@id": "r1wudgxahdha", "@type": "ImpactAssessment"}, "impactAssessmentIsProxy": false, "isAnimalFeed": true, "@type": "Input", "properties": [{"term": {"@type": "Term", "name": "Dry matter", "termType": "property", "@id": "dryMatter", "units": "%"}, "value": 87.6522952853598, "share": 100, "@type": "Property", "methodModel": {"@type": "Term", "@id": "hestia", "name": "HESTIA", "termType": "model"}, "updated": ["term", "value"], "updatedVersion": ["0.70.0", "0.70.0"], "added": ["methodModel", "term", "value", "share"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "name": "Crude protein content", "termType": "property", "@id": "crudeProteinContent", "units": "%"}, "value": 19.5, "share": 100, "@type": "Property", "updated": ["term", "value"], "updatedVersion": ["0.70.0", "0.70.0"], "added": ["term", "value", "share"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "name": "Calcium content", "termType": "property", "@id": "calciumContent", "units": "%"}, "value": 0.95, "share": 100, "@type": "Property", "updated": ["term", "value"], "updatedVersion": ["0.70.0", "0.70.0"], "added": ["term", "value", "share"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "name": "Phosphorus content (as P)", "termType": "property", "@id": "phosphorusContentAsP", "units": "%"}, "value": 0.6, "share": 100, "@type": "Property", "updated": ["term", "value"], "updatedVersion": ["0.70.0", "0.70.0"], "added": ["term", "value", "share"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "name": "Sodium content", "termType": "property", "@id": "sodiumContent", "units": "%"}, "value": 0.18, "share": 100, "@type": "Property", "updated"