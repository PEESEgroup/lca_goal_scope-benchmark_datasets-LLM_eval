t, lorry", "units": "tkm", "@id": "freightLorry"}, "value": 124.96, "min": 14.08, "max": 176, "statsDefinition": "cycles", "returnLegIncluded": false, "methodClassification": "estimated with assumptions", "methodClassificationDescription": "For mass of manure handled (i.e. for the purpose of quantifying manure transport), the following assump- tions were also implemented: A) for liquid manure management systems, mass of manure handled was assumed equivalent to the mass of manure excreted, B) for dry manure management systems, mass of manure handled was assumed equivalent to 50% of the mass of manure excreted for stockpiled manure subject to uncovered storage, and 33% of the mass of manure excreted for stockpiled manure subject to covered storage, and C) for free range and organic systems, it was assumed that 50% of manure was excreted outdoors and was not subject to handling", "@type": "Transport"}], "primary": false, "@type": "Product", "currency": "USD", "price": 0, "added": ["currency", "price"], "addedVersion": ["0.70.0", "0.70.0"]}, {"@type": "Product", "term": {"@type": "Term", "@id": "excretaPoultryKgN", "name": "Excreta, poultry (kg N)", "termType": "excreta", "units": "kg N"}, "value": [148.91712], "model": {"@type": "Term", "@id": "pooreNemecek2018", "name": "Poore & Nemecek (2018)", "termType": "model"}, "added": ["term", "value", "model"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}, {"term": {"@type": "Term", "@id": "excretaPoultryKgVs", "name": "Excreta, poultry (kg VS)", "termType": "excreta", "units": "kg VS"}, "@type": "Product", "value": [2219.9003218054363], "model": {"@type": "Term", "@id": "pooreNemecek2018", "name": "Poore & Nemecek (2018)", "termType": "model"}, "added": ["term", "value", "model"], "addedVersion": ["0.70.0", "0.70.0", "0.70.0"]}], "transformations": [{"term": {"@type": "Term", "name": "Solid storage, covered/compacted", "termType": "excretaManagement", "@id": "solidStorageCoveredCompacted"}, "inputs": [{"term": {"@type": "