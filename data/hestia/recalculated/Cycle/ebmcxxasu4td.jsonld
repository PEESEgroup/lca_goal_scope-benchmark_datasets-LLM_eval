{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-04-17", "updatedAt": "2025-04-25", "@id": "ebmcxxasu4td", "@type": "Cycle", "description": "Aggregate cycle representing data from 4 farms in the Central-East mesoregion on Parana in 2019, all producing milk under a semi-confinement system, where animals spend part of each day on pasture, and the remainder confined", "endDate": "2019", "functionalUnit": "relative", "functionalUnitDetails": "1 kg FPCM", "site": {"@type": "Site", "@id": "zsezugzaj4yz"}, "otherSites": [{"@type": "Site", "@id": "lrp0t4n3vget"}], "defaultSource": {"@id": "v9neu-ph4e_r", "@type": "Source"}, "defaultMethodClassification": "verified survey data", "defaultMethodClassificationDescription": "A structured questionnaire was created. The questionnaire was previously tested through interviews with specialists in the area to certify the consistency of the questions and the compliance with the data quality criteria.  Most of the data provided in the inventories is primary, collected in the field, through on-site interviews with farm owners and managers and expert technical consultants from the agro-industrial cooperative. After completion, the three inventories were sent for external review, where 5 specialists critically provided feedback on the inventories. After such review, the inventories were submitted to the SICV/Brazil. The external review was carried out by five professionals trained in both LCA and milk production who do not belong to the team who conducted this study and the reviewers did not report any known conflict of interest related to reviewing those inventories.", "inputs": [{"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [0.00036767493551570783], "@type": "Input"}, {"term": {"@type": "Term", "name": "Electricity, grid, market mix", "termType": "electricity", "@id": "electricityGridMarketMix", "units": "kWh"}, "value": [0.10594598507270803], "@type": "Input"}, {"term": {"@type": "Term", "termType": "water", "name": "Water, pumped groundwater", "units": "m3", "@id": "waterPumpedGroundwater"}, "value": [0.0038430844756053057], "operation": {"@type": "Term", "name": "Providing animals with water", "termType": "operation", "@id": "providingAnimalsWithWater", "units": "hour"}, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Maize, silage", "units": "kg", "@id": "maizeSilage"}, "value": [0.3757675802879292], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "forage", "name": "Ryegrass, fresh forage", "units": "kg", "@id": "ryegrassFreshForage"}, "value": [0.0768703851744186], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "forage", "name": "Danthonia, fresh forage", "units": "kg", "@id": "danthoniaFreshForage"}, "value": [0.032944450789036545], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "termType": "crop", "name": "Soybean, meal", "units": "kg", "@id": "soybeanMeal"}, "value": [0.031065612887596898], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Sodium chloride", "termType": "feedFoodAdditive", "@id": "sodiumChloride", "units": "kg"}, "value": [0.004431465946843854], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Generic grass, hay", "termType": "crop", "@id": "genericGrassHay", "units": "kg"}, "value": [0.0038872508305647837], "isAnimalFeed": true, "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Nitrogen fertiliser, unspecified (kg N)", "termType": "inorganicFertiliser", "@id": "inorganicNitrogenFertiliserUnspecifiedKgN", "units": "kg N"}, "value": [0.005542437321531522], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Phosphorus fertiliser, unspecified (kg P2O5)", "termType": "inorganicFertiliser", "@id": "inorganicPhosphorusFertiliserUnspecifiedKgP2O5", "units": "kg P2O5"}, "value": [0.001570418