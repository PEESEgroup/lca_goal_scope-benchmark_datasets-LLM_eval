{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-03-19", "updatedAt": "2025-04-25", "@id": "al4jqrvstfmj", "@type": "Cycle", "site": {"@type": "Site", "@id": "uispwoomut3u"}, "defaultSource": {"@id": "xjw-lobrpjl_", "@type": "Source"}, "description": "Production of Nelore beef (Bos indicus) bulls for slaughter", "endDate": "2012-12-31", "startDateDefinition": "start of year", "cycleDuration": 365, "siteDuration": 365, "functionalUnit": "relative", "functionalUnitDetails": "1 kg liveweight", "defaultMethodClassification": "expert opinion", "defaultMethodClassificationDescription": "To characterize the typical beef farm, members of CEPEA (Center for Advanced Studies on Applied Economics located in the Luiz de Queiroz College of Agriculture at the University of S~ao Paulo in Piracicaba-Brazil), in collaboration with technical staff of local farmers' unions, prepared a Microsoft Excel® worksheet to collect typical farm data. In 2012, a team from CEPEA characterized the typical farm through a focus group of local farmers and technical staff from the local farmers' unions. Economic and technical features of the typical beef farming system in the region were discussed with focus group participants (e.g. livestock flows, animal life cycle, livestock weights, technical indices, farm inputs and outputs). Through consensus of focus-group participants, data for the typical farm were considered representative of beef farms in the region.", "practices": [{"term": {"@type": "Term", "name": "Herd replacement rate", "termType": "animalManagement", "@id": "herdReplacementRate", "units": "%"}, "value": [26], "description": "Replacement rate (%) for reproducing females", "@type": "Practice"}, {"term": {"@type": "Term", "termType": "animalManagement", "name": "Overall culling rate, female", "units": "%", "@id": "overallCullingRateFemale"}, "value": [25], "description": "Number of culled reproducing females (100 cows)", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Overall mortality rate", "termType": "animalManagement", "@id": "overallMortalityRate", "units": "%"}, "value": [1.8624641833810889], "description": "Total number of cattle lost during cycle (9) over total cattle (698)", "@type": "Practice"}, {"term": {"@type": "Term", "termType": "animalManagement", "name": "Overall mortality rate, female", "units": "%", "@id": "overallMortalityRateFemale"}, "value": [0.7285974499089253], "description": "4 female cattle (2 calves, 2 heifers) lost out of total female cattle", "@type": "Practice"}, {"term": {"@type": "Term", "termType": "animalManagement", "name": "Overall mortality rate, male", "units": "%", "@id": "overallMortalityRateMale"}, "value": [3.3557046979865772], "description": "5 male cattle (2 calves, 3 bulls) lost over 149 male cattle total", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Stocking density, permanent pasture (average)", "termType": "animalManagement", "@id": "stockingDensityPermanentPastureAverage", "units": "animals / m2"}, "value": [6.979999999999999e-05], "description": "Study lists 0.83 animal units (AU) per hectare using average animal weight of 450 kg. We use the time corrected number of animals.", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Total animal population", "termType": "animalManagement", "@id": "totalAnimalPopulation", "units": "number"}, "value": [698], "description": "See 'Animal Calculations' sheet in excel upload to see how herd size was calculated.", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Pasture grass", "termType": "landUseManagement", "@id": "pastureGrass", "units": "% area"}, "value": [100], "description": "Brachiaria decumbens grasswas seeded without addition of fertilizer.", "@type": "Practice"}, {"term": {"@type": "Term", "name": "Continuous grazing", "termType": "landUseManagement", "@id": "continuousGrazing", "units": "% area"}, "value": [100], "description": "The farm has no rotational grazing system.