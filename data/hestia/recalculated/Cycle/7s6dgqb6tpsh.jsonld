{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-02-09", "updatedAt": "2025-04-25", "@id": "7s6dgqb6tpsh", "@type": "Cycle", "description": "Annual production cycle of a grass-based UK dairy farm on a high sugar grass (HSG), increasingly used in UK livestock holdings.", "startDateDefinition": "one year prior", "endDate": "2016", "cycleDuration": 365, "functionalUnit": "relative", "site": {"@type": "Site", "@id": "m1sgeuqku4ud"}, "siteArea": 105, "siteDuration": 185, "siteUnusedDuration": 180, "otherSites": [{"@type": "Site", "@id": "xp3w1yflkhra"}], "otherSitesDuration": [180], "otherSitesUnusedDuration": [185], "defaultSource": {"@id": "dyejpjpyu9fe", "@type": "Source"}, "defaultMethodClassification": "consistent external sources", "defaultMethodClassificationDescription": "Representative farm typologies were used to ensure that results relate to typical UK grazing-based dairy systems, using a variety of sources. Farm structure and inputs (excluding feed) were defined according to the major extensive, pasture-based dairy farm typology identified from statistical anlaysis of 14 years of UK dairy farm statistics (Gonzalez-Mejia et al., 2018). Feeding regime used information from a recent meta-analysis on HSG systems (Foskolos and Moorby, 2017) and outputs from the Cornell Net Carbohydrate and Protein System (CNCPS; Van Amburgh et al., 2015) feed model.", "inputs": [{"term": {"@type": "Term", "termType": "fuel", "name": "Diesel", "units": "kg", "@id": "diesel"}, "value": [6343.049999999999], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Nitrogen fertiliser, unspecified (kg N)", "termType": "inorganicFertiliser", "@id": "inorganicNitrogenFertiliserUnspecifiedKgN", "units": "kg N"}, "value": [22155], "@type": "Input"}, {"term": {"@type": "Term", "name": "Inorganic Phosphorus fertiliser, unspecified (kg P2O5)", "termType": "inorganicFertiliser", "@id": "inorganicPhosphorusFertiliserUnspecifiedKgP2O5", "units": "kg