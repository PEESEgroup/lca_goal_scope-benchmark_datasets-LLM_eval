{"@context": "https://www-staging.hestia.earth/schema/Cycle.jsonld", "createdAt": "2024-03-19", "updatedAt": "2025-04-25", "@id": "ad6deo092xev", "@type": "Cycle", "site": {"@type": "Site", "@id": "knpbw431byhi"}, "defaultSource": {"@id": "xjw-lobrpjl_", "@type": "Source"}, "description": "Production of Beef", "endDate": "2012-12-31", "functionalUnit": "relative", "functionalUnitDetails": "1 kg carcass weight", "defaultMethodClassification": "expert opinion", "defaultMethodClassificationDescription": "To characterize the typical beef farm, members of CEPEA (Center for Advanced Studies on Applied Economics located in the Luiz de Queiroz College of Agriculture at the University of S~ao Paulo in Piracicaba-Brazil), in collaboration with technical staff of local farmers' unions, prepared a Microsoft Excel® worksheet to collect typical farm data. In 2012, a team from CEPEA characterized the typical farm through a focus group of local farmers and technical staff from the local farmers' unions. Economic and technical features of the typical beef farming system in the region were discussed with focus group participants (e.g. livestock flows, animal life cycle, livestock weights, technical indices, farm inputs and outputs). Through consensus of focus-group participants, data for the typical farm were considered representative of beef farms in the region.", "inputs": [{"term": {"@type": "Term", "termType": "liveAnimal", "name": "Beef cattle, bull", "units": "number", "@id": "beefCattleBull"}, "value": [144], "impactAssessment": {"@id": "juxgzkr7a0sc", "@type": "ImpactAssessment"}, "impactAssessmentIsProxy": true, "@type": "Input", "properties": [{"term": {"@type": "Term", "name": "Liveweight per head", "termType": "property", "@id": "liveweightPerHead", "units": "kg liveweight / head"}, "value": 490, "description": "144 bulls are fattened to 490 kg and sold to a slaughterhouse each year", "share": 100, "@type": "Property", "added": ["term", "value", "description", "share"], "