{"@context":"https://www.hestia.earth/schema/Source.jsonld","createdAt":"2023-11-13","updatedAt":"2025-05-22","@id":"x--pwvqu1uzz","@type":"Source","dataPrivate":false,"originalLicense":"no public license","bibliography":{"documentDOI":"10.1016/j.jclepro.2019.06.171","title":"Understanding uncertainty in the carbon footprint of beef production","name":"Sykes et al (2019)","authors":[{"@id":"2j7glxgmpdr6","@type":"Actor"},{"@id":"czyxxm7zyrya","@type":"Actor"},{"@id":"wkl4mrz3jxvi","@type":"Actor"}],"outlet":"Journal of Cleaner Production","year":2019,"mendeleyID":"2f2608f1-a57e-3932-afb7-9919a932422a","scopus":"2-s2.0-85067883433","@type":"Bibliography"},"uploadNotes":"Recorded GWP value - unlear whether the \"per kg LW\" FU quoted for the figure given in the text refers to liveweight of both finished and cull cattle, or just the finished steers. Suckling calves and finishing animals from 13 to 19 months were at pasture and did not require fed rations. All other animal classes spent 5 months housed (and 7 months at pasture).","name":"Sykes et al (2019)","uploadBy":{"@type":"Actor","@id":"6230a4e702ca0d00133e2028"},"schemaVersion":"32.1.1","validationDate":"2025-05-22","validationBy":[{"@type":"Actor","@id":"5eb26d6bc3513500132349b3"}],"originalId":"1"}