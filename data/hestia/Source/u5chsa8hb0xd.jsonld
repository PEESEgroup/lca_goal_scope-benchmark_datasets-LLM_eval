{"@context":"https://www.hestia.earth/schema/Source.jsonld","createdAt":"2023-11-09","updatedAt":"2025-05-21","@id":"u5chsa8hb0xd","@type":"Source","bibliography":{"title":"Environmental footprint and sustainability of horticulture (including potatoes)–A comparison with other agricultural sectors","documentDOI":"10.13140/RG.2.2.19874.89280","year":2007,"outlet":"University of Wawick","name":"Lillywhite et al (2007)","authors":[{"@id":"gfydjtnbo1ss","@type":"Actor"},{"@id":"kwzlxm6dlqwu","@type":"Actor"},{"@id":"qdasewi8wynb","@type":"Actor"},{"@id":"r0oa856gdtpq","@type":"Actor"}],"mendeleyID":"e9fbd64c-3025-3e4c-a051-f8e0f4aca091","@type":"Bibliography"},"dataPrivate":false,"originalLicense":"no public license","uploadNotes":"The study is very unclear about what is actually happening in the Lincolnshire farm (page 59 onwards). Given the site area is different and the years of harvest do not match with the given rotation order, we assumed the crops are not actually in a rotation.","name":"Lillywhite et al (2007)","uploadBy":{"@type":"Actor","@id":"624eea0769b9420013214fa6"},"schemaVersion":"32.1.1","validationDate":"2025-05-21","validationBy":[{"@type":"Actor","@id":"624eea0769b9420013214fa6"}],"originalId":"1"}